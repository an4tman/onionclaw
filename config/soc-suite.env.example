# ============================================================================
# onionclaw — site configuration
# ----------------------------------------------------------------------------
# Copy this file to `soc-suite.env` and fill in YOUR environment's values.
# Every value the suite needs that differs between deployments lives here, so
# the scripts and prompts carry no hardcoded IPs, hostnames, paths, or IDs.
#
#   cp soc-suite.env.example soc-suite.env && $EDITOR soc-suite.env
#
# This file is sourced by the orchestration shell scripts and read by the
# Python helpers. It holds NO secrets — Security Onion and threat-intel
# credentials live in the gateway's own `so.env` / `ti.env` (see
# docs/03-mcp-deployment.md). Keep `soc-suite.env` out of version control.
# ============================================================================

# ── Your network ────────────────────────────────────────────────────────────
# The trusted LAN CIDR(s) the analyst treats as "internal". Used for grounding
# and (informally) to reason about direction of traffic.
SOC_LAN_CIDR="192.168.1.0/24"

# ── Security Onion ──────────────────────────────────────────────────────────
# The SO manager/sensor. SO's nginx checks the Host header, so the gateway must
# reach it by the name SO expects (SOC_SO_HOSTNAME), mapped to its IP via a
# Docker --add-host. The Elasticsearch URL is what the read-only ES MCP bridges.
SOC_SO_IP="192.168.1.50"
SOC_SO_HOSTNAME="securityonion.local"
SOC_SO_URL="https://securityonion.local"
SOC_SO_ES_URL="https://192.168.1.50:9200"

# ── MCP gateway host + ports ────────────────────────────────────────────────
# SOC_DOCKER_HOST is the machine (by hostname or IP) that runs the two MCP
# containers — typically the same box that runs OpenClaw. The ports are where
# the MCP HTTP endpoints are published.
SOC_DOCKER_HOST="docker-host"
SOC_ES_MCP_PORT="9220"          # read-only Elasticsearch bridge  -> http://$HOST:9220/mcp
SOC_SO_GATEWAY_PORT="9221"      # SO Core API gateway (this repo) -> http://$HOST:9221/mcp

# ── OpenClaw runtime (the headless-cycle host) ──────────────────────────────
# The autonomous cycle + IR team run as headless Claude Code INSIDE the
# OpenClaw container, authenticated with an Anthropic API key. These paths are
# inside that container.
SOC_OPENCLAW_CONTAINER="OpenClaw"
SOC_AGENT_HOME="/root/.openclaw/soc-agent"            # where cycle/IR files are installed
SOC_CLAUDE_BIN="/root/.openclaw/npm-global/bin/claude" # Claude Code binary in-container
SOC_CLAUDE_ENV="/root/.openclaw/claude.env"            # sources Claude Code auth (ANTHROPIC_API_KEY)
SOC_CLAUDE_CONFIG_DIR="/root/.openclaw/claude"         # isolated CLAUDE_CONFIG_DIR

# The cloud model the cycle/IR team drive their tools with (NOT a local model —
# local heavy models loop on tool calls; see docs/04-openclaw-setup.md).
SOC_CLOUD_MODEL="anthropic/claude-sonnet-5"

# ── Grounding write path (optional; the learn flow, docs/08) ─────────────────
# Host DIRECTORY holding the canonical environment.md (e.g. the OpenClaw-managed
# skill copy's references/ dir). When set, the gateway mounts it and enables the
# gated propose/apply/revert_grounding tools so the operator can teach the
# analyst from Discord (`learn <entity>: <what it is>`). Leave empty to run
# without the grounding write path.
SOC_GROUNDING_DIR=""

# ── Delivery (Discord, via OpenClaw's bot) ──────────────────────────────────
# The channel the cycle/IR briefings post to. Format: `channel:<id>`.
# Operator interaction (approve/revert/investigate) happens in this channel.
SOC_DISCORD_CHANNEL="channel:<your-discord-channel-id>"

# ── Schedule ────────────────────────────────────────────────────────────────
SOC_CYCLE_CRON="0 12 * * *"     # once daily at noon
SOC_TZ="America/New_York"

# ── Log forwarder (optional — see orchestration/soc-log-forwarder.py) ───────
# Ships pihole + OpenClaw logs to SO over syslog/UDP so they show up in Elastic.
SOC_SYSLOG_PORT="514"
SOC_PIHOLE_LOG="/mnt/user/appdata/pihole/logs/pihole.log"
SOC_OPENCLAW_LOG_DIR="/mnt/user/appdata/openclaw/logs"
