# operator-gate service config — copy to operator-gate.env and chmod 600.
# Keep out of version control.

# The SAME Discord bot token OpenClaw uses (this service only posts/reads via REST,
# so sharing the token causes no gateway conflict).
DISCORD_TOKEN=<bot-token>

# The channel where the operator interacts (the SOC/operator channel).
OPERATOR_CHANNEL_ID=<channel-id>

# Your Discord user id — ONLY reactions from this user are treated as decisions.
OPERATOR_USER_ID=<your-user-id>

# The so-gateway MCP endpoint (used by the tuning-approval watcher to apply on ✅).
# Default assumes both containers share a docker network and resolve by name.
SO_GATEWAY_URL=http://mcp-so-gateway:8080/mcp

# Optional:
# WATCH_APPROVALS=false      # disable the tuning watcher; expose only ask_operator
# ASK_TIMEOUT_SECONDS=600    # default ask_operator wait
